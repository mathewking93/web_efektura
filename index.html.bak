<!DOCTYPE html>
<html lang="cs">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Efektura — Jakub Strejc, architekt</title>
<meta name="description" content="Efektura — architektonické studio Jakuba Strejce. Navrhuji prostory, které mají charakter, logiku a trvají.">
<link rel="icon" href="favicon.ico" sizes="any">
<link rel="icon" href="icons/favicon-32.png" type="image/png" sizes="32x32">
<link rel="icon" href="icons/favicon-16.png" type="image/png" sizes="16x16">
<link rel="apple-touch-icon" href="icons/apple-touch-icon.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:          #0A0A0A;
    --surface:     #111111;
    --surface-2:   #161616;
    --ink:         #FFFFFF;
    --ink-mid:     rgba(255,255,255,.65);
    --ink-muted:   rgba(255,255,255,.35);
    --accent:      #EA3323;
    --accent-lt:   #F06A5A;
    --accent-dark: #C02418;
    --brand-bg:    #0A0A0A;
    --line:        rgba(255,255,255,.08);
    --line-red:    rgba(234,51,35,.5);
    --white:       #FFFFFF;

    --serif: 'Cormorant Garamond', Georgia, serif;
    --sans:  'Jost', sans-serif;

    --nav-h: 72px;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--ink);
    font-family: var(--sans);
    font-weight: 300;
    font-size: 16px;
    line-height: 1.7;
    cursor: crosshair;
    overflow-x: hidden;
  }

  a { color: inherit; text-decoration: none; }

  img { display: block; width: 100%; height: 100%; object-fit: cover; }

  /* ─── SCROLLBAR ─── */
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: #0A0A0A; }
  ::-webkit-scrollbar-thumb { background: var(--accent); }

  /* ─── NAV ─── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    height: var(--nav-h);
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 clamp(24px, 5vw, 80px);
    background: var(--brand-bg);
    transition: box-shadow .3s;
  }
  nav.scrolled {
    box-shadow: 0 1px 0 rgba(255,255,255,.08);
  }
  .nav-logo {
    display: flex; align-items: center;
    flex-shrink: 0;
  }
  .nav-logo-img {
    height: 28px;
    width: auto;
    display: block;
    /* PNG má černé pozadí — screen blend mode ho "odstraní" na tmavé liště */
    mix-blend-mode: screen;
    filter: brightness(1.05);
  }
  .nav-links {
    display: flex; gap: 40px;
    list-style: none;
    font-size: 11px;
    font-weight: 400;
    letter-spacing: .14em;
    text-transform: uppercase;
  }
  .nav-links a {
    color: rgba(255,255,255,.5);
    transition: color .2s;
    position: relative;
  }
  .nav-links a::after {
    content: '';
    position: absolute; bottom: -3px; left: 0; right: 0; height: 1px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform .3s;
  }
  .nav-links a:hover { color: #fff; }
  .nav-links a:hover::after { transform: scaleX(1); }
  .nav-hamburger {
    display: none;
    flex-direction: column; gap: 5px;
    background: none; border: none; cursor: crosshair; padding: 4px;
  }
  .nav-hamburger span {
    display: block; width: 24px; height: 1px; background: rgba(255,255,255,.6);
    transition: transform .3s, opacity .3s;
  }

  /* ─── HERO ─── */
  #hero {
    height: 100dvh;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
  }

  /* video pozadí */
  .hero-video-wrap {
    position: absolute; inset: 0; z-index: 0;
  }
  .hero-video-wrap video {
    width: 100%; height: 100%;
    object-fit: cover;
    filter: grayscale(25%) contrast(1.08);
  }
  /* fallback obrázek pokud video není k dispozici */
  .hero-video-wrap img {
    width: 100%; height: 100%;
    object-fit: cover;
    filter: grayscale(25%) contrast(1.08);
  }

  /* vícevrstvý overlay: tmavý spod (čitelnost textu) + jemný gradient shora */
  .hero-overlay {
    position: absolute; inset: 0; z-index: 1;
    background:
      linear-gradient(to top,  rgba(10,10,10,.82) 0%,  rgba(10,10,10,.35) 45%, rgba(10,10,10,.15) 100%),
      linear-gradient(to right, rgba(10,10,10,.4) 0%, transparent 60%);
  }

  /* tenká červená linka nahoře — brandový detail */
  #hero::before {
    content: '';
    position: absolute; top: var(--nav-h); left: 0; right: 0;
    height: 1px;
    background: linear-gradient(to right, var(--accent) 0%, transparent 50%);
    z-index: 3;
    opacity: .6;
  }

  .hero-content {
    position: relative; z-index: 2;
    width: 100%;
    padding: clamp(40px, 8vh, 100px) clamp(24px, 5vw, 80px);
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: flex-end;
    gap: 40px;
  }

  .hero-left {}

  .hero-eyebrow {
    font-size: 11px;
    font-weight: 400;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 24px;
    opacity: 0;
    animation: fadeUp .8s .2s forwards;
  }
  .hero-name {
    font-family: var(--serif);
    font-size: clamp(56px, 9vw, 120px);
    font-weight: 300;
    line-height: .92;
    letter-spacing: -.02em;
    color: #fff;
    margin-bottom: 32px;
    opacity: 0;
    animation: fadeUp .8s .4s forwards;
  }
  .hero-name em {
    display: block;
    font-style: italic;
    color: rgba(255,255,255,.55);
  }
  .hero-desc {
    font-size: 15px;
    color: rgba(255,255,255,.55);
    max-width: 340px;
    line-height: 1.8;
    border-left: 1px solid var(--accent);
    padding-left: 20px;
    margin-bottom: 48px;
    opacity: 0;
    animation: fadeUp .8s .6s forwards;
  }
  .hero-cta {
    display: inline-flex; align-items: center; gap: 12px;
    font-size: 12px;
    font-weight: 400;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: #fff;
    opacity: 0;
    animation: fadeUp .8s .8s forwards;
    transition: gap .3s;
  }
  .hero-cta:hover { gap: 20px; }
  .hero-cta-line {
    width: 40px; height: 1px;
    background: var(--accent);
    transition: width .3s;
  }
  .hero-cta:hover .hero-cta-line { width: 60px; }

  /* pravá část — video ovládání + stat */
  .hero-right-info {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: flex-end;
    gap: 24px;
    opacity: 0;
    animation: fadeUp .8s 1s forwards;
  }
  .hero-stat {
    text-align: right;
    border-right: 1px solid rgba(255,255,255,.2);
    padding-right: 20px;
  }
  .hero-stat-val {
    font-family: var(--serif);
    font-size: 44px; font-weight: 300;
    color: var(--accent);
    line-height: 1;
  }
  .hero-stat-label {
    font-size: 11px; letter-spacing: .14em;
    text-transform: uppercase;
    color: rgba(255,255,255,.35);
    margin-top: 4px;
  }

  /* mute/unmute tlačítko */
  .hero-mute-btn {
    display: flex; align-items: center; gap: 8px;
    background: rgba(255,255,255,.08);
    border: 1px solid rgba(255,255,255,.15);
    color: rgba(255,255,255,.5);
    font-family: var(--sans);
    font-size: 10px; letter-spacing: .14em; text-transform: uppercase;
    padding: 9px 16px;
    cursor: crosshair;
    transition: background .2s, color .2s, border-color .2s;
  }
  .hero-mute-btn:hover { background: rgba(255,255,255,.14); color: #fff; border-color: rgba(255,255,255,.3); }
  .hero-mute-btn svg { width: 14px; height: 14px; stroke: currentColor; stroke-width: 1.5; fill: none; flex-shrink: 0; }

  .hero-scroll {
    position: absolute; bottom: 40px; left: 50%; transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: 8px;
    font-size: 10px; letter-spacing: .18em; text-transform: uppercase;
    color: rgba(255,255,255,.35);
    z-index: 10;
    opacity: 0;
    animation: fadeUp .6s 1.2s forwards;
  }
  .hero-scroll-line {
    width: 1px; height: 48px; background: var(--accent);
    animation: scrollPulse 2s 1.4s infinite;
  }

  /* ─── SECTION HELPERS ─── */
  .section-pad { padding: clamp(80px, 12vh, 140px) clamp(24px, 5vw, 80px); }

  /* červená linka jako oddělovač sekcí */
  .section-divider {
    height: 1px;
    background: var(--accent);
    margin: 0;
  }

  .section-header {
    display: flex; align-items: baseline; gap: 20px;
    margin-bottom: clamp(48px, 8vh, 80px);
  }
  .section-num {
    font-size: 11px; font-weight: 400;
    letter-spacing: .15em; color: var(--accent);
    flex-shrink: 0;
  }
  .section-title {
    font-family: var(--serif);
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: -.01em;
    color: var(--white);
  }
  .section-line {
    flex: 1; height: 1px;
    background: var(--accent); opacity: .4;
    align-self: center; margin-left: 12px;
  }

  /* ─── PROJECTS ─── */
  #projekty { background: var(--bg); }

  .projects-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--accent); /* červené mezery mezi kartami */
  }
  .project-card {
    position: relative; overflow: hidden;
    cursor: crosshair;
    background: var(--bg);
  }
  .project-card:first-child { grid-row: span 2; }
  .project-card-img {
    width: 100%; height: 100%; min-height: 320px;
    overflow: hidden;
  }
  .project-card:first-child .project-card-img { min-height: 640px; }
  .project-card-img img {
    transition: transform .7s ease, filter .7s ease;
    filter: grayscale(30%) brightness(.9);
  }
  .project-card:hover .project-card-img img {
    transform: scale(1.06);
    filter: grayscale(0%) brightness(1);
  }
  .project-card-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,.9) 0%, transparent 55%);
    display: flex; flex-direction: column; justify-content: flex-end;
    padding: 32px;
    transition: background .4s;
  }
  .project-card:hover .project-card-overlay {
    background: linear-gradient(to top, rgba(0,0,0,.95) 0%, rgba(0,0,0,.25) 60%);
  }
  .project-cat {
    font-size: 10px; font-weight: 400; letter-spacing: .2em;
    text-transform: uppercase; color: var(--accent);
    margin-bottom: 6px;
    transform: translateY(6px); opacity: 0;
    transition: transform .4s, opacity .4s;
  }
  .project-card:hover .project-cat { transform: translateY(0); opacity: 1; }
  .project-name {
    font-family: var(--serif);
    font-size: clamp(22px, 3vw, 36px);
    font-weight: 400;
    color: var(--white);
    line-height: 1.15;
    margin-bottom: 8px;
  }
  .project-meta {
    font-size: 12px; color: rgba(255,255,255,.4);
    display: flex; gap: 16px;
  }
  .project-btn {
    position: absolute; top: 24px; right: 24px;
    width: 40px; height: 40px;
    border: 1px solid rgba(234,51,35,.4);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    opacity: 0; transform: scale(.8);
    transition: opacity .3s, transform .3s, background .2s, border-color .2s;
  }
  .project-btn svg { width: 14px; height: 14px; fill: none; stroke: var(--white); stroke-width: 1.5; }
  .project-card:hover .project-btn { opacity: 1; transform: scale(1); }
  .project-btn:hover { background: var(--accent); border-color: var(--accent); }

  /* ─── LIGHTBOX ─── */
  #lightbox {
    position: fixed; inset: 0; z-index: 200;
    background: rgba(0,0,0,.97);
    display: flex; flex-direction: column;
    opacity: 0; pointer-events: none;
    transition: opacity .4s;
  }
  #lightbox.open { opacity: 1; pointer-events: all; }
  .lb-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 24px clamp(24px, 5vw, 80px);
    border-bottom: 1px solid var(--line);
    flex-shrink: 0;
  }
  .lb-title { font-family: var(--serif); font-size: 28px; font-weight: 300; color: var(--white); }
  .lb-meta { font-size: 12px; color: var(--ink-muted); margin-top: 2px; }
  .lb-close {
    width: 44px; height: 44px;
    border: 1px solid rgba(255,255,255,.15); border-radius: 50%;
    background: none; cursor: crosshair;
    display: flex; align-items: center; justify-content: center;
    transition: background .2s, border-color .2s;
  }
  .lb-close:hover { background: var(--accent); border-color: var(--accent); }
  .lb-close svg { width: 16px; height: 16px; stroke: var(--white); stroke-width: 1.5; fill: none; }
  .lb-body {
    flex: 1; overflow-y: auto;
    padding: 48px clamp(24px, 8vw, 160px);
    display: grid; grid-template-columns: 1.4fr 1fr; gap: 64px;
    align-items: start;
  }
  .lb-gallery { display: flex; flex-direction: column; gap: 12px; }
  .lb-gallery-main { aspect-ratio: 4/3; overflow: hidden; border-radius: 2px; }
  .lb-gallery-main img { width: 100%; height: 100%; object-fit: cover; }
  .lb-gallery-thumbs { display: flex; gap: 8px; }
  .lb-thumb {
    width: 80px; height: 56px; overflow: hidden; border-radius: 2px;
    opacity: .35; cursor: crosshair; transition: opacity .2s;
    border: 1px solid transparent; flex-shrink: 0;
  }
  .lb-thumb.active { opacity: 1; border-color: var(--accent); }
  .lb-thumb:hover { opacity: .7; }
  .lb-info { padding-top: 8px; }
  .lb-info-title { font-family: var(--serif); font-size: 40px; font-weight: 300; color: var(--white); line-height: 1.1; margin-bottom: 4px; }
  .lb-info-sub { font-size: 12px; letter-spacing: .15em; text-transform: uppercase; color: var(--accent); margin-bottom: 24px; }
  .lb-info-desc { font-size: 15px; color: var(--ink-mid); line-height: 1.85; margin-bottom: 32px; }
  .lb-info-table { width: 100%; border-collapse: collapse; }
  .lb-info-table tr { border-bottom: 1px solid var(--line); }
  .lb-info-table td { padding: 10px 0; font-size: 13px; }
  .lb-info-table td:first-child { color: var(--ink-muted); width: 40%; }
  .lb-info-table td:last-child { color: var(--ink-mid); }
  .lb-nav {
    position: absolute; bottom: 32px; right: clamp(24px, 5vw, 80px);
    display: flex; gap: 8px;
  }
  .lb-nav-btn {
    width: 44px; height: 44px;
    border: 1px solid rgba(255,255,255,.15); border-radius: 50%;
    background: none; cursor: crosshair;
    display: flex; align-items: center; justify-content: center;
    transition: background .2s, border-color .2s;
  }
  .lb-nav-btn:hover { background: var(--accent); border-color: var(--accent); }
  .lb-nav-btn svg { width: 14px; height: 14px; stroke: var(--white); stroke-width: 1.5; fill: none; }

  /* ─── SPOLUPRÁCE ─── */
  #spoluprace { background: var(--bg); color: var(--white); }
  #spoluprace .section-title { color: var(--white); }
  #spoluprace .section-num { color: var(--accent); }
  #spoluprace .section-line { background: var(--accent); opacity: .4; }

  .collab-steps {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0;
    position: relative;
  }
  .collab-steps::before {
    content: '';
    position: absolute;
    top: 32px; left: 32px; right: 32px;
    height: 1px;
    background: var(--accent); opacity: .35;
  }
  .collab-step { padding: 0 24px 0 0; position: relative; }
  .collab-step-num {
    width: 64px; height: 64px;
    border: 1px solid rgba(234,51,35,.3);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--serif);
    font-size: 22px; font-weight: 300;
    color: var(--accent);
    margin-bottom: 24px;
    background: var(--bg);
    position: relative; z-index: 1;
    transition: background .3s, border-color .3s;
  }
  .collab-step:hover .collab-step-num {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--white);
  }
  .collab-step-title {
    font-family: var(--serif);
    font-size: 20px; font-weight: 400;
    color: var(--white);
    margin-bottom: 10px; line-height: 1.2;
  }
  .collab-step-desc {
    font-size: 13px; color: var(--ink-muted);
    line-height: 1.75;
  }

  /* scrollovatelný kontejner na mobilu */
  .process-wrap {
    overflow-x: auto;
    padding-bottom: 16px;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: var(--accent) rgba(255,255,255,.05);
  }
  .process-wrap::-webkit-scrollbar { height: 2px; }
  .process-wrap::-webkit-scrollbar-track { background: rgba(255,255,255,.05); }
  .process-wrap::-webkit-scrollbar-thumb { background: var(--accent); }

  /* ─── PROCESS DIAGRAM — dvě linie ─── */
  .process-wrap {
    overflow-x: auto;
    padding-bottom: 16px;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: var(--accent) rgba(255,255,255,.05);
  }
  .process-wrap::-webkit-scrollbar { height: 2px; }
  .process-wrap::-webkit-scrollbar-track { background: rgba(255,255,255,.05); }
  .process-wrap::-webkit-scrollbar-thumb { background: var(--accent); }

  /*
   * SVG diagram se renderuje jako inline SVG — CSS pouze obaluje kontejner
   */
  .process-svg-wrap {
    min-width: 900px;
    width: 100%;
  }
  .process-svg-wrap svg {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── legenda ── */
  .process-legend {
    display: flex;
    gap: 32px;
    margin-top: 40px;
    padding-top: 28px;
    border-top: 1px solid rgba(255,255,255,.07);
    flex-wrap: wrap;
  }
  .process-legend-item {
    display: flex; align-items: center; gap: 10px;
    font-size: 11px; letter-spacing: .1em; text-transform: uppercase;
    color: rgba(255,255,255,.4);
  }
  .process-legend-line {
    width: 28px; height: 2px; flex-shrink: 0;
  }
  .process-legend-line.white { background: rgba(255,255,255,.7); }
  .process-legend-line.red   { background: var(--accent); }

  /* ─── O MNĚ ─── */
  #omne { background: var(--bg); }
  .about-grid {
    display: grid; grid-template-columns: 1fr 1.1fr;
    gap: clamp(48px, 8vw, 120px);
    align-items: center;
  }
  .about-img-wrap { position: relative; }
  .about-img-wrap::before {
    content: '';
    position: absolute;
    top: -20px; left: -20px;
    width: 60%; height: 60%;
    border: 1px solid rgba(234,51,35,.3);
    z-index: 0; pointer-events: none;
  }
  .about-img {
    position: relative; z-index: 1;
    aspect-ratio: 3/4; overflow: hidden;
  }
  .about-intro {
    font-family: var(--serif);
    font-size: clamp(24px, 3.5vw, 40px);
    font-weight: 300;
    line-height: 1.25;
    letter-spacing: -.01em;
    margin-bottom: 32px;
    color: var(--white);
  }
  .about-intro em { font-style: italic; color: var(--accent); }
  .about-body {
    font-size: 15px; color: var(--ink-mid);
    line-height: 1.85; margin-bottom: 40px;
  }
  .about-body p + p { margin-top: 16px; }
  .about-tags {
    display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 40px;
  }
  .about-tag {
    font-size: 11px; letter-spacing: .14em;
    text-transform: uppercase;
    border: 1px solid rgba(234,51,35,.3);
    padding: 7px 16px;
    color: var(--ink-muted);
    transition: border-color .2s, color .2s;
  }
  .about-tag:hover { border-color: var(--accent); color: var(--accent); }
  .about-nums {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 24px;
    padding-top: 32px;
    border-top: 1px solid rgba(234,51,35,.2);
  }
  .about-num-val {
    font-family: var(--serif);
    font-size: 48px; font-weight: 300;
    color: var(--accent); line-height: 1;
    margin-bottom: 4px;
  }
  .about-num-label {
    font-size: 12px; color: var(--ink-muted);
    letter-spacing: .1em; text-transform: uppercase;
  }

  /* ─── KONTAKT ─── */
  #kontakt { background: var(--bg); color: var(--white); }
  #kontakt .section-title { color: var(--white); }
  #kontakt .section-num { color: var(--accent); }
  #kontakt .section-line { background: var(--accent); opacity: .4; }

  .contact-layout {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: clamp(48px, 8vw, 120px);
    align-items: start;
  }
  .contact-big-email {
    font-family: var(--serif);
    font-size: clamp(28px, 4vw, 52px);
    font-weight: 300;
    color: var(--white);
    line-height: 1.15;
    margin-bottom: 48px;
    display: inline-flex; align-items: center; gap: 16px;
    border-bottom: 1px solid rgba(234,51,35,.3);
    padding-bottom: 20px; width: 100%;
    transition: color .2s, border-color .2s;
  }
  .contact-big-email:hover { color: var(--accent); border-color: var(--accent); }
  .contact-big-email svg { width: 28px; height: 28px; stroke: currentColor; stroke-width: 1; fill: none; flex-shrink: 0; }
  .contact-info { margin-bottom: 40px; }
  .contact-info-row {
    display: flex; justify-content: space-between;
    padding: 13px 0;
    border-bottom: 1px solid var(--line);
    font-size: 14px;
  }
  .contact-info-row:first-child { border-top: 1px solid var(--line); }
  .contact-info-label { color: var(--ink-muted); font-size: 11px; letter-spacing: .1em; text-transform: uppercase; }
  .contact-info-val { color: var(--ink-mid); text-align: right; }
  .contact-social { display: flex; gap: 20px; margin-top: 32px; }
  .contact-social-link {
    font-size: 11px; letter-spacing: .14em; text-transform: uppercase;
    color: var(--ink-muted);
    border-bottom: 1px solid transparent; padding-bottom: 2px;
    transition: color .2s, border-color .2s;
  }
  .contact-social-link:hover { color: var(--accent); border-color: var(--accent); }
  .contact-cta-block { padding-top: 8px; }
  .contact-cta-text {
    font-family: var(--serif);
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 300;
    color: var(--white);
    line-height: 1.3; margin-bottom: 28px;
  }
  .contact-cta-text em { font-style: italic; color: var(--ink-muted); }
  .contact-cta-btn {
    display: inline-flex; align-items: center; gap: 14px;
    background: var(--accent); color: var(--white);
    font-family: var(--sans); font-size: 12px; font-weight: 400;
    letter-spacing: .14em; text-transform: uppercase;
    padding: 18px 32px;
    transition: background .2s, gap .3s;
    border: none; text-decoration: none;
  }
  .contact-cta-btn:hover { background: var(--accent-dark); gap: 20px; }
  .contact-cta-btn svg { width: 14px; height: 14px; stroke: currentColor; stroke-width: 1.5; fill: none; }

  /* ─── FOOTER ─── */
  footer {
    padding: 32px clamp(24px, 5vw, 80px);
    background: var(--brand-bg);
    display: flex; justify-content: space-between; align-items: center;
    font-size: 12px; color: rgba(255,255,255,.35);
    letter-spacing: .06em;
  }
  footer a { color: rgba(255,255,255,.35); transition: color .2s; }
  footer a:hover { color: var(--accent); }
  footer .footer-logo { color: var(--accent); font-weight: 500; letter-spacing: .18em; text-transform: uppercase; font-size: 13px; }

  /* ─── ANIMATIONS ─── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes scrollPulse {
    0%, 100% { opacity: 1; transform: scaleY(1); transform-origin: top; }
    50% { opacity: .3; transform: scaleY(.4); transform-origin: top; }
  }

  .reveal {
    opacity: 0; transform: translateY(28px);
    transition: opacity .7s ease, transform .7s ease;
  }
  .reveal.visible { opacity: 1; transform: translateY(0); }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 900px) {
    #hero { align-items: flex-end; }
    .hero-content { grid-template-columns: 1fr; }
    .hero-right-info { align-items: flex-start; flex-direction: row; flex-wrap: wrap; }
    .hero-stat { text-align: left; border-right: none; border-left: 1px solid rgba(255,255,255,.2); padding-right: 0; padding-left: 20px; }

    .projects-grid { grid-template-columns: 1fr; }
    .project-card:first-child { grid-row: auto; }

    .collab-steps { grid-template-columns: 1fr 1fr; gap: 32px; }
    .collab-steps::before { display: none; }

    .about-grid { grid-template-columns: 1fr; }
    .about-img-wrap { max-width: 360px; }

    .contact-layout { grid-template-columns: 1fr; }

    .lb-body { grid-template-columns: 1fr; padding: 32px 24px; }
    .lb-info { padding-top: 0; }
    .lb-info-title { font-size: 28px; }
  }
  @media (max-width: 640px) {
    .nav-links { display: none; }
    .nav-hamburger { display: flex; }
    .form-row { grid-template-columns: 1fr; }
    footer { flex-direction: column; gap: 8px; text-align: center; }
  }

  /* mobile nav overlay */
  .mobile-nav {
    position: fixed; inset: 0; z-index: 99;
    background: #0A0A0A;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 40px;
    opacity: 0; pointer-events: none;
    transition: opacity .3s;
  }
  .mobile-nav.open { opacity: 1; pointer-events: all; }
  .mobile-nav a {
    font-family: var(--serif);
    font-size: 40px; font-weight: 300;
    color: rgba(255,255,255,.8);
    letter-spacing: -.01em;
  }
  .mobile-nav a:hover { color: var(--accent); }
</style>
</head>
